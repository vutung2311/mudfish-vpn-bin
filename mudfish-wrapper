#!/bin/bash
# Mudfish wrapper script to dynamically apply MTU and quickack to TAP routes.


SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
REAL_MUDFISH="$SCRIPT_DIR/mudfish-real"

# Cleanup function to ensure monitor is killed if wrapper is terminated
cleanup() {
    echo "Terminating route monitor and mudfish..."
    kill "$MONITOR_PID" "$MUDFISH_PID" 2>/dev/null
    wait "$MUDFISH_PID" 2>/dev/null
}
trap cleanup EXIT INT TERM

# 1. Launch mudfish-real first
"$REAL_MUDFISH" "$@" &
MUDFISH_PID=$!

# 2. Start the route monitor in the background to do route updating
(
    MTU_SET_DEV=""
    /usr/bin/ip monitor route | while read -r line; do
        if { [[ "$line" =~ "dev tap" ]] || [[ "$line" =~ "dev tun" ]]; } && [[ "$line" =~ "via" ]] && [[ ! "$line" =~ "Deleted" ]] && [[ ! "$line" =~ "quickack" ]]; then
            # Parse route details quickly using native bash regex match
            if [[ "$line" =~ ^([^[:space:]]+)[[:space:]]+via[[:space:]]+([^[:space:]]+)[[:space:]]+dev[[:space:]]+([^[:space:]]+) ]]; then
                prefix="${BASH_REMATCH[1]}"
                gateway="${BASH_REMATCH[2]}"
                dev="${BASH_REMATCH[3]}"
                
                if [ -n "$prefix" ] && [ -n "$gateway" ] && [ -n "$dev" ]; then
                    # Configure interface properties once per interface session
                    if [ "$MTU_SET_DEV" != "$dev" ]; then
                        # Clamp MTU to 1380
                        /usr/bin/ip link set dev "$dev" mtu 1380 2>/dev/null || true
                        # Apply CAKE qdisc for latency optimization
                        /usr/bin/tc qdisc replace dev "$dev" root cake bandwidth 100mbit besteffort wash rtt 80ms raw overhead 0 2>/dev/null || true
                        MTU_SET_DEV="$dev"
                    fi
                    # Set quickack 1
                    /usr/bin/ip route change "$prefix" via "$gateway" dev "$dev" quickack 1 2>/dev/null || true
                fi
            fi
        fi
    done
) &
MONITOR_PID=$!

# 3. Wait for mudfish-real to exit
wait "$MUDFISH_PID"
EXIT_STATUS=$?

# Clean up monitor process
kill "$MONITOR_PID" 2>/dev/null
wait "$MONITOR_PID" 2>/dev/null

exit $EXIT_STATUS
